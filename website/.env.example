# === Kartenbot Dashboard — Konfiguration ===
# Kopieren nach website/.env und Werte anpassen. Die .env wird NICHT committet.

# Pfad zur Bot-Datenbank (relativ zum Projekt-Root oder absolut)
KARTENBOT_DB_PATH=kartenbot.db

# Pfad zur Bot-Logdatei
KARTENBOT_LOG_PATH=bot.log

# Passwort für Admin-Aktionen (PFLICHT für Schreibzugriffe — ohne Passwort
# ist das Dashboard rein lesend)
DASHBOARD_PASSWORD=

# Optional: festes Secret für Session-Cookies (sonst pro Start zufällig)
#DASHBOARD_SESSION_SECRET=

# Optional: Host/Port (Standard: 127.0.0.1:8080; im Docker 0.0.0.0)
#DASHBOARD_HOST=127.0.0.1
#DASHBOARD_PORT=8080

# Optional: Zeitzone für Tages-/Stunden-Auswertungen
#DASHBOARD_TZ=Europe/Vienna
